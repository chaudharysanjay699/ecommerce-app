# ── Application ──────────────────────────────────────────
PROJECT_NAME="Ecom Delivery API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# ── PostgreSQL (used by docker-compose) ──────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecom_db
POSTGRES_PORT=5432

# ── Database (used by the FastAPI app) ───────────────────
# Local development (app runs outside Docker):
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/ecom_db"
# Inside Docker the override in docker-compose.yml sets @db:5432 automatically.
DB_ECHO=false

# ── Security ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY="change-me-generate-a-secure-random-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OTP ───────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
# ── Firebase Cloud Messaging (FCM) ──────────────────────────
# Get from Firebase Console → Project settings → General → Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id
#
# Option A – file path to the downloaded service account JSON:
FIREBASE_SERVICE_ACCOUNT_JSON=/path/to/serviceAccountKey.json
#
# Option B – inline JSON string (useful for CI/CD and Docker secrets):
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...", ...}'
# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS='["http://localhost:3000","http://localhost:3001","http://localhost:8080"]'

# ── File upload ───────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE=5242880

# ── API port exposed by docker-compose ───────────────────
API_PORT=8000
